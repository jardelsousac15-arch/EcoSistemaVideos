# ECOSYSTEM — variáveis de ambiente
# Copie este arquivo para .env e preencha com suas chaves

# Porta do servidor (padrão: 8000)
PORT=8000

# Suas chaves de API (não commitar no git!)
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# Configurações opcionais
MAX_FRAME_COUNT=20
DEFAULT_QUALITY=90
CORS_ORIGINS=*
